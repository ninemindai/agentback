{
  "name": "hello-hosts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "start:fastify": "node --enable-source-maps dist/fastify.js",
    "start:hono": "node --enable-source-maps dist/hono.js",
    "start:native": "node --enable-source-maps dist/native.js",
    "start:bun": "bun run src/bun.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/openapi": "workspace:~",
    "@agentback/rest": "workspace:~",
    "@hono/node-server": "^2.0.5",
    "fastify": "^5.8.5",
    "hono": "^4.12.23",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "engines": {
    "node": ">=22.13"
  }
}
