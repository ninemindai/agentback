{
  "name": "@agentback/files-s3",
  "version": "0.5.1",
  "description": "S3-backed FileStore adapter for @agentback/files (AWS SDK v3 + lib-storage streaming)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/files": "workspace:~",
    "@aws-sdk/client-s3": "^3.1069.0",
    "@aws-sdk/lib-storage": "^3.1069.0",
    "@aws-sdk/s3-request-presigner": "^3.1069.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "vitest": "~4.1.9"
  },
  "engines": {
    "node": ">=22.13"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
