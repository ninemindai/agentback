{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["es2022", "esnext.disposable", "dom"],
    "types": ["node", "react", "react-dom"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "src/client/main.tsx",
    "src/client/pages.tsx",
    "src/client/css.d.ts"
  ],
  "references": [
    {"path": "../console-theme"},
    {"path": "../rest"},
    {"path": "../context-explorer"},
    {"path": "../rest-explorer"},
    {"path": "../mcp-inspector"},
    {"path": "../schema-explorer"},
    {"path": "../testlab"}
  ]
}
