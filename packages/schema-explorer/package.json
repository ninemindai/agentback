{
  "name": "@agentback/schema-explorer",
  "version": "0.2.0",
  "description": "Schema/domain entity explorer: every Zod schema as a node, with provenance edges to every REST route, MCP tool, and Drizzle table that uses it",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./console": "./src/client/console-page.tsx"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b && node build-client.mjs",
    "build:client": "node build-client.mjs",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@agentback/console-theme": "workspace:~",
    "@agentback/core": "workspace:~",
    "@agentback/mcp": "workspace:~",
    "@agentback/metadata": "workspace:~",
    "@agentback/openapi": "workspace:~",
    "@agentback/rest": "workspace:~",
    "@types/express": "^4.17.21",
    "express": "^4.22.0",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "devDependencies": {
    "@agentback/testlab": "workspace:~",
    "@dagrejs/dagre": "^1.1.4",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "@types/supertest": "^7.2.0",
    "@xyflow/react": "~12.11.0",
    "esbuild": "~0.28.0",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "supertest": "^7.2.2",
    "vitest": "~4.1.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
    "directory": "packages/schema-explorer"
  },
  "homepage": "https://agentback.dev",
  "bugs": "https://github.com/ninemindai/agentback/issues"
}
