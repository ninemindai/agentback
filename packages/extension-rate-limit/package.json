{
  "name": "@agentback/extension-rate-limit",
  "version": "0.2.2",
  "description": "Rate-limiting middleware (rate-limiter-flexible) — in-memory or Redis-backed, with 429 + RateLimit headers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/rest": "workspace:~",
    "@types/express": "^4.17.21",
    "rate-limiter-flexible": "~11.1.1",
    "tslib": "^2.8.1"
  },
  "engines": {
    "node": ">=22.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
    "directory": "packages/extension-rate-limit"
