{
  "name": "@agentback/messaging",
  "version": "0.0.1",
  "description": "Transport-agnostic messaging ports (JobQueue/EventBus/QueueAdmin/Scheduler) with typed Zod descriptors and an in-memory adapter",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/conformance.d.ts",
      "import": "./dist/testing/conformance.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/common": "workspace:*",
    "@agentback/core": "workspace:*",
    "@agentback/metadata": "workspace:*",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "~4.1.8"
  },
  "engines": {
    "node": ">=22.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
    "directory": "packages/messaging"
  },
  "homepage": "https://agentback.dev",
  "bugs": "https://github.com/ninemindai/agentback/issues"
}
