{
  "name": "@agentback/testing",
  "version": "0.3.0",
  "description": "First-class test harness: createTestApp with binding overrides, typed in-process REST client, supertest bridge, and in-memory MCP client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/client": "workspace:~",
    "@agentback/context": "workspace:~",
    "@agentback/core": "workspace:~",
    "@agentback/rest": "workspace:~",
    "@agentback/testlab": "workspace:~",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@agentback/mcp": "workspace:~",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependenciesMeta": {
    "@agentback/mcp": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.13"
  },
  "devDependencies": {
    "@agentback/authorization": "workspace:~",
    "@agentback/mcp": "workspace:~",
    "@agentback/openapi": "workspace:~",
    "@agentback/security": "workspace:~",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vitest": "~4.1.9",
    "zod": "^4.4.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
    "directory": "packages/testing"
  },
  "homepage": "https://agentback.dev",
  "bugs": "https://github.com/ninemindai/agentback/issues"
}
