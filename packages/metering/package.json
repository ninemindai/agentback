{
  "name": "@agentback/metering",
  "version": "0.0.1",
  "description": "Rail-neutral usage metering for REST + MCP calls: per-principal UsageEvents, pluggable sink (audit log), and per-principal quota",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/authentication": "workspace:*",
    "@agentback/context": "workspace:*",
    "@agentback/core": "workspace:*",
    "@agentback/mcp": "workspace:*",
    "@agentback/metadata": "workspace:*",
    "@agentback/openapi": "workspace:*",
    "@agentback/rest": "workspace:*",
    "@agentback/security": "workspace:*",
    "@types/express": "^4.17.21",
    "nanoid": "^5.1.11",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@agentback/testlab": "workspace:*",
    "vitest": "~4.1.8"
  },
  "engines": {
    "node": ">=22.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
    "directory": "packages/metering"
  },
  "homepage": "https://agentback.dev",
  "bugs": "https://github.com/ninemindai/agentback/issues"
}
