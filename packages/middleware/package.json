{
  "name": "@agentback/middleware",
  "version": "0.6.0",
  "description": "Runtime-neutral middleware chain machinery (Express-free) shared by @agentback/rest and the @agentback/express host",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/common": "workspace:~",
    "@agentback/context": "workspace:~",
    "@agentback/core": "workspace:~",
    "@types/cors": "~2.8.19",
    "@types/express": "^5.0.6",
    "@types/on-finished": "^2.3.5",
    "debug": "^4.4.3",
    "on-finished": "^2.4.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@agentback/testlab": "workspace:~",
    "@types/debug": "^4.1.13",
    "express": "^5.2.1",
    "vitest": "~4.1.9"
  },
  "engines": {
    "node": ">=22.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
