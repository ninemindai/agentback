{
  "name": "@agentback/config",
  "version": "0.2.0",
  "description": "Zod-validated, env-aware config loader (JSONC + YAML) with layered overlays and DI bindings",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@agentback/common": "workspace:~",
    "@agentback/context": "workspace:~",
    "@agentback/core": "workspace:~",
    "@types/debug": "^4.1.13",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "jsonc-parser": "^3.3.1",
    "tslib": "^2.8.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@agentback/testlab": "workspace:~",
    "vitest": "~4.1.8"
  },
  "engines": {
    "node": ">=22.13"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninemindai/agentback.git",
    "directory": "packages/config"
  },
  "homepage": "https://agentback.dev",
  "bugs": "https://github.com/ninemindai/agentback/issues"
